FROM python:3.10-slim-bullseye

RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc g++ zip libglib2.0-0 libsm6 libxext6 libxrender-dev libx11-xcb1 \
    libxcb-icccm4 libxcb-image0 libxcb-keysyms1 libxcb-randr0 libxcb-render-util0 \
    libxcb-xinerama0 libxcb-xfixes0 libxcb-cursor0 libxkbcommon-x11-0 \
    libfontconfig1 libdbus-1-3 libgl1 libegl1 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY requirements.txt .
COPY packaging/build-requirements.txt packaging/build-requirements.txt
RUN pip install --no-cache-dir -r packaging/build-requirements.txt
RUN pip install --no-cache-dir -r requirements.txt

# Copy source
COPY . .

# Run unified desktop build
CMD ["python3", "build_qt.py"]
